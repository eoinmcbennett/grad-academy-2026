{
  "name": "eayl-academy-2025",
  "version": "1.0.0",
  "description": "Welcome to the EAYL Academy 2025 repository! This contains educational materials, presentations, and resources for the academy program.",
  "main": "index.js",
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@slidev/cli": "^52.2.4",
    "@slidev/theme-default": "^0.25.0"
  },
  "scripts": {
    "dev:app-config": "slidev slides/app-configuration/app-configuration.md",
    "dev:crypto": "slidev slides/cryptography-101/cryptography-101.md",
    "dev:di": "slidev slides/di/dependency_injection.md",
    "dev:js-ts": "slidev slides/js-vs-ts/js_ts_comparison.md",
    "dev:logging": "slidev slides/logging/logging-practices.md",
    "dev:password-storage": "slidev slides/password-storage/password-storage.md",
    "dev:github-copilot": "slidev slides/github-copilot/github-copilot.md",
    "dev:web-authentication": "slidev slides/web-authentication/web-authentication.md",
    "dev:prompt-engineering": "slidev slides/prompt-engineering/prompt-engineering.md",
    "dev:prompt-engineering-models": "slidev slides/prompt-engineering-models/prompt-engineering-models.md",
    "dev:git-workflows": "slidev slides/git-workflows/git-workflows.md",
    "build:app-config": "slidev build slides/app-configuration/app-configuration.md --out dist/app-configuration",
    "build:crypto": "slidev build slides/cryptography-101/cryptography-101.md --out dist/cryptography-101",
    "build:di": "slidev build slides/di/dependency_injection.md --out dist/di",
    "build:js-ts": "slidev build slides/js-vs-ts/js_ts_comparison.md --out dist/js-ts",
    "build:logging": "slidev build slides/logging/logging-practices.md --out dist/logging",
    "build:password-storage": "slidev build slides/password-storage/password-storage.md --out dist/password-storage",
    "build:github-copilot": "slidev build slides/github-copilot/github-copilot.md --out dist/github-copilot",
    "build:web-authentication": "slidev build slides/web-authentication/web-authentication.md --out dist/web-authentication",
    "build:prompt-engineering": "slidev build slides/prompt-engineering/prompt-engineering.md --out dist/prompt-engineering",
    "build:prompt-engineering-models": "slidev build slides/prompt-engineering-models/prompt-engineering-models.md --out dist/prompt-engineering-models",
    "build:git-workflows": "slidev build slides/git-workflows/git-workflows.md --out dist/git-workflows",
    "build:all": "npm run build:app-config && npm run build:crypto && npm run build:di && npm run build:github-copilot && npm run build:git-workflows && npm run build:js-ts && npm run build:logging && npm run build:password-storage && npm run build:prompt-engineering && npm run build:prompt-engineering-models && npm run build:web-authentication",
    "export:app-config-pdf": "slidev export slides/app-configuration/app-configuration.md --output slides/app-configuration/app-configuration.pdf",
    "export:crypto-pdf": "slidev export slides/cryptography-101/cryptography-101.md --output slides/cryptography-101/cryptography-101.pdf",
    "export:di-pdf": "slidev export slides/di/dependency_injection.md --output slides/di/dependency_injection.pdf",
    "export:js-ts-pdf": "slidev export slides/js-vs-ts/js_ts_comparison.md --output slides/js-vs-ts/js_ts_comparison.pdf",
    "export:logging-pdf": "slidev export slides/logging/logging-practices.md --output slides/logging/logging-practices.pdf",
    "export:password-storage-pdf": "slidev export slides/password-storage/password-storage.md --output slides/password-storage/password-storage.pdf",
    "export:github-copilot-pdf": "slidev export slides/github-copilot/github-copilot.md --output slides/github-copilot/github-copilot.pdf",
    "export:web-authentication-pdf": "slidev export slides/web-authentication/web-authentication.md --output slides/web-authentication/web-authentication.pdf",
    "export:prompt-engineering-pdf": "slidev export slides/prompt-engineering/prompt-engineering.md --output slides/prompt-engineering/prompt-engineering.pdf",
    "export:prompt-engineering-models-pdf": "slidev export slides/prompt-engineering-models/prompt-engineering-models.md --output slides/prompt-engineering-models/prompt-engineering-models.pdf",
    "export:git-workflows-pdf": "slidev export slides/git-workflows/git-workflows.md --output slides/git-workflows/git-workflows.pdf",
    "export:all": "npm run export:app-config-pdf && npm run export:crypto-pdf && npm run export:di-pdf && npm run export:github-copilot-pdf && npm run export:git-workflows-pdf && npm run export:js-ts-pdf && npm run export:logging-pdf && npm run export:password-storage-pdf && npm run export:prompt-engineering-pdf && npm run export:prompt-engineering-models-pdf && npm run export:web-authentication-pdf",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
